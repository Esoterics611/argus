# Proxy pool — residential, per-context rotation
PROXY_POOL_URL=http://user:pass@proxy-provider.example.com:PORT

# Storage
QUESTDB_URL=postgresql://admin:quest@localhost:8812/qdb
NATS_URL=nats://localhost:4222

# Optional: MinIO for parquet cold layer
# MINIO_ENDPOINT=localhost:9001
# MINIO_ACCESS_KEY=argus
# MINIO_SECRET_KEY=argus_secret
# MINIO_BUCKET=argus-parquet

# Sink selection: memory | parquet | questdb | nats
ARGUS_SINK=parquet
ARGUS_PARQUET_DIR=data/parquet

# Stealth backend: vanilla | stealth | patchright | camoufox
ARGUS_STEALTH_BACKEND=vanilla
